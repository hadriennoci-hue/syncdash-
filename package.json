{
  "name": "syncdash",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:cf": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && wrangler dev",
    "build": "next build",
    "deploy": "opennextjs-cloudflare deploy",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute syncdash-db --local --file=./drizzle/0001_init.sql",
    "db:migrate2": "wrangler d1 execute syncdash-db --local --file=./drizzle/0002_product_customs_fields.sql",
    "db:migrate4": "wrangler d1 execute syncdash-db --local --file=./drizzle/0004_warehouse_channel_priority.sql",
    "db:migrate5": "wrangler d1 execute syncdash-db --local --file=./drizzle/0005_channel_sync.sql",
    "db:migrate6": "wrangler d1 execute syncdash-db --local --file=./drizzle/0006_fix_suppliers.sql",
    "db:migrate7": "wrangler d1 execute syncdash-db --local --file=./drizzle/0007_push_status.sql",
    "db:studio": "drizzle-kit studio",
    "db:seed": "wrangler d1 execute syncdash-db --local --file=./drizzle/seed.sql"
  },
  "dependencies": {
    "@mendable/firecrawl-js": "^1.9.0",
    "@opennextjs/cloudflare": "^1.16.5",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@tanstack/react-query": "^5.56.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.33.0",
    "lucide-react": "^0.441.0",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260228.0",
    "@types/node": "^22.5.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@vitest/ui": "^2.1.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.24.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.45",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.11",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1",
    "wrangler": "^3.78.0"
  }
}
